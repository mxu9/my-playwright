# audit_helper_poc 配置文件模板
# 复制此文件为 .env 并填入实际值

# API 配置
API_KEY=your_api_key_here
BASE_URL=https://api.example.com/v1
MODEL_NAME=gpt-4o
TEMPERATURE=0.1

# 日志配置
LOG_LEVEL=INFO

# -------------------
# PDF Processing Parameters
# -------------------
TEXT_DENSITY_THRESHOLD=0.0001
PAGES_FOR_CLASSIFICATION=2

# 跳过指定类型的 PDF（逗号分隔，用于手工测试）
# 例如：SKIP_CATEGORIES=房租合同,银行明细对账单
# 空值或未设置表示不跳过任何类型
# 参考 PDF_CATEGORIES 中定义的类别
SKIP_CATEGORIES=